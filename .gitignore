# no cache files
.ipynb_checkpoints/
*/.ipynb_checkpoints/
*/__pycache__/
*.pyc
*.pyo
*.pyd
*.swp

# don't track changes to netcdf files
*.nc

# don't track changes to core data
cores/data/*

# Prerequisites
*.d

# Compiled Object files
*.slo
*.lo
*.o
*.obj

# Precompiled Headers
*.gch
*.pch

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# Fortran module files
*.mod
*.smod

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

#no executables
*.x
bin/*
*.exe
*.out
*.app


# mac specific
*.DS_STORE

# Ignore pointlists
launch_job/pointlists/

# Ignore reference files -- too big
reference/FGRN055/*
reference/ANT27/*

# Ignore temp files, acts as scratch
temp/

# Ignore modules and objects
modules/
objects/

# Ignore build artifacts (Jupyter Book / docs)
_build/

# Ignore log directories (slurm .err/.out, run logs)
logs/

# Ignore large MO-fit data -- see MO_fit/README.md for download/access instructions
MO_fit/data/sumup/source/*
MO_fit/figures/*
MO_fit/data/PKM/source/*
MO_fit/data/PKM/raw/*
.nfs*

#No claude files
*.claude.md*
